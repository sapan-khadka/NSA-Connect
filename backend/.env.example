# Application
APP_NAME="NSA Connect API"
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nsa_connect

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-only-secret-change-me-before-production-deploy
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# Rate limiting (Redis-backed; see app/core/rate_limit.py for IP derivation)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_PROXY_HEADERS=false
RATE_LIMIT_LOGIN_IP_MAX=10
RATE_LIMIT_LOGIN_ACCOUNT_FAILURES_MAX=10
RATE_LIMIT_REGISTER_IP_MAX=5
RATE_LIMIT_CHANGE_PASSWORD_MAX=5
RATE_LIMIT_GUEST_CHECKIN_EVENT_IP_MAX=5
RATE_LIMIT_GUEST_CHECKIN_GLOBAL_IP_MAX=30
RATE_LIMIT_GLOBAL_MAX=120

# Email via SendGrid (set EMAIL_ENABLED=true in production)
EMAIL_ENABLED=false
EMAIL_FROM="NSA Connect <noreply@semo.edu>"
SENDGRID_API_KEY=

# Resend (notification email foundation)
RESEND_API_KEY=
RESEND_FROM_EMAIL="NSA Connect <onboarding@resend.dev>"
# When set, all notification emails go here instead of real recipients (dev/testing only)
EMAIL_TEST_OVERRIDE_RECIPIENT=

# Web app URL for links in transactional emails
FRONTEND_URL=http://localhost:5173

# Cloudinary (receipts + event photo archive)
# Leave blank in development to store event photos locally under backend/dev_uploads/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_RECEIPTS_FOLDER=nsa-connect/finance-receipts
CLOUDINARY_EVENT_PHOTOS_FOLDER=nsa-connect/event-photos

# Used when resolving local dev photo paths for album zip downloads
DEV_UPLOAD_BASE_URL=http://127.0.0.1:8000

# Anthropic AI (set AI_ENABLED=true when ready)
AI_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI embeddings for constitution pgvector storage
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
