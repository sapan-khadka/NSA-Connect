# Application
APP_NAME="NSA Connect API"
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nsa_connect

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (use a strong random value in production)
SECRET_KEY=dev-only-secret-change-me-before-production-deploy
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email via SendGrid (set EMAIL_ENABLED=true in production)
EMAIL_ENABLED=false
EMAIL_FROM="NSA Connect <noreply@semo.edu>"
SENDGRID_API_KEY=
