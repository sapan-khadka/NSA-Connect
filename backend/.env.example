# Application
APP_NAME="NSA Connect API"
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nsa_connect

# Redis
REDIS_URL=redis://localhost:6379/0

# Security (use a strong random value in production)
SECRET_KEY=dev-only-secret-change-me-before-production-deploy
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email via SendGrid (set EMAIL_ENABLED=true in production)
EMAIL_ENABLED=false
EMAIL_FROM="NSA Connect <noreply@semo.edu>"
SENDGRID_API_KEY=

# Cloudinary receipt uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_RECEIPTS_FOLDER=nsa-connect/finance-receipts

# Anthropic AI (set AI_ENABLED=true when ready)
AI_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
