# Copy to backup/.env (never commit). Used by the db-backup Docker service and host runs.

# --- Database (backup container uses Docker network hostname "postgres") ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nsa_connect
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nsa_connect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# When running scripts on the host against Docker Postgres (optional override)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433

# --- Local storage ---
BACKUP_DIR=/backups
BACKUP_LOG_FILE=/backups/backup.log

# --- Encryption (required for cloud upload; openssl AES-256-CBC + PBKDF2) ---
# Generate: openssl rand -base64 32
BACKUP_ENCRYPTION_PASSPHRASE=

# --- S3-compatible cloud storage (AWS S3, Cloudflare R2, GCS via S3 interop) ---
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=nsa-connect-backups
BACKUP_S3_PREFIX=production
# R2 example: https://<account_id>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto

# --- Retention ---
BACKUP_DAILY_RETENTION_DAYS=30
BACKUP_WEEKLY_RETENTION_WEEKS=12
# 0=Sunday … 6=Saturday (UTC); Sunday backup is also kept as weekly
BACKUP_WEEKLY_DAY=0

# --- Verification ---
# After each backup, restore into a throwaway DB and validate schema
BACKUP_VERIFY_RESTORE=true
BACKUP_VERIFY_DB_PREFIX=nsa_connect_verify

# --- Notifications (on failure only) ---
BACKUP_NOTIFY_ON_FAILURE=true
BACKUP_DISCORD_WEBHOOK_URL=
# Optional email via Resend HTTP API
BACKUP_RESEND_API_KEY=
BACKUP_ALERT_EMAIL_TO=ops@semo.edu
BACKUP_ALERT_EMAIL_FROM=NSA Connect Backups <onboarding@resend.dev>

# --- Scheduler mode (set by docker-compose for db-backup service) ---
# BACKUP_MODE=scheduled | manual
